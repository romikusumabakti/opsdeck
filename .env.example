# Copy to `.env` (Docker Compose) or `.env.local` (host `next dev`) and fill in.

# --- Database ---
# Used by the `postgres` service in compose.yaml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=opsdeck

# App connection string. With Compose, host is `postgres`; on the host, `localhost`.
DATABASE_URL=postgres://postgres:CHANGE_ME@postgres:5432/opsdeck

# --- Timezone ---
# IANA timezone name. Applies to all date/time displays in the app.
# Defaults to Asia/Jakarta if unset.
APP_TIMEZONE=Asia/Jakarta

# --- Whitelabel branding (baked into client bundle at build time) ---
NEXT_PUBLIC_APP_NAME="OpsDeck"
NEXT_PUBLIC_COMPANY_NAME="Your Company"
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=example.com

# --- Auth (better-auth) ---
BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME

# --- Email (Resend) — optional; email features disabled if empty ---
RESEND_API_KEY=
# Defaults to `<APP_NAME> <no-reply@ALLOWED_EMAIL_DOMAIN>` when unset.
EMAIL_FROM=

# --- Inngest (production self-hosted) ---
# Compose runs the Inngest server with `inngest start` (production mode) backed
# by Postgres + Valkey, and sets the app's INNGEST_DEV=0 / INNGEST_BASE_URL.
# Leave INNGEST_DEV empty here; only set it (e.g. `http://localhost:8288`) when
# running the bundled `inngest dev` server outside Docker for local work.
INNGEST_DEV=
#
# Keys: must be hex strings with an even number of chars. Generate with:
#   openssl rand -hex 32
# The same values are read by both the app (to sign events) and the inngest
# server (to verify them) — keep them in sync.
INNGEST_EVENT_KEY=CHANGE_ME
INNGEST_SIGNING_KEY=CHANGE_ME
#
# Durable storage for the inngest server. Use a DEDICATED `inngest` database,
# separate from the app's POSTGRES_DB. Create it once before first start:
#   docker compose exec postgres createdb -U postgres inngest
INNGEST_POSTGRES_URI=postgres://postgres:CHANGE_ME@postgres:5432/inngest

# --- Object storage (Garage) — knowledge-base image attachments ---
# Garage server secrets (compose `garage` service). Generate once:
#   GARAGE_RPC_SECRET:  openssl rand -hex 32
#   GARAGE_ADMIN_TOKEN: openssl rand -base64 32
GARAGE_RPC_SECRET=CHANGE_ME
GARAGE_ADMIN_TOKEN=CHANGE_ME
#
# App S3 client. ENDPOINT is the in-network Garage S3 API; on the host use
# http://localhost:3900. ACCESS/SECRET are created once via the garage CLI
# AFTER first boot (see README "Object storage setup") — leave them blank on the
# initial `docker compose up`, then fill them in and restart the app. The stack
# boots fine without them; only image uploads need them.
S3_ENDPOINT=http://garage:3900
S3_REGION=garage
S3_BUCKET=knowledge
S3_ACCESS_KEY=
S3_SECRET_KEY=
