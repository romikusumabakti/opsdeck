# Public edge for dss-panel. Caddy reverse-proxies to the app container over the
# compose network. Serves plain HTTP — no TLS.
#
# WARNING: HTTP only. Login credentials and session cookies travel in plaintext.
# Acceptable only on a trusted LAN. The domain (dss-int.id) is private and not
# publicly registered, so a browser-trusted cert isn't obtainable for it; TLS was
# dropped by choice to avoid per-device CA installs. To re-enable HTTPS, switch to
# a publicly-owned hostname (e.g. panel.dssconsulting.id) with Let's Encrypt
# DNS-01, or use `tls internal` and trust Caddy's root CA on every client.
#
# The `http://` prefix disables Caddy's automatic HTTPS (no TLS, no 80->443
# redirect); Caddy listens on :80 only.
http://panel.dss-int.id {
	reverse_proxy app:3000 {
		# Next standalone doesn't trust X-Forwarded-* for nextUrl, so next-intl's
		# absolute locale redirects leak the internal listen port (:3000) into the
		# Location header. Strip it on the way back out.
		header_down Location ":3000/" "/"
	}
}
