# Public edge for dss-panel. Caddy terminates TLS and reverse-proxies to the
# app container over the compose network. It forwards X-Forwarded-Host/Proto so
# Next builds redirects from the public origin (fixes the internal :3000 leak).
#
# `tls internal` issues a cert from Caddy's own local CA. The domain is private
# (dss-int.id -> 192.168.x.x), so public ACME (Let's Encrypt) can't validate it.
# Clients must trust Caddy's root CA, OR replace this with a cert from your
# internal CA:  tls /path/cert.pem /path/key.pem
# To serve plain HTTP instead, change the site address to `http://panel.dss-int.id`
# and drop the tls line (then set BETTER_AUTH_URL back to http://).
panel.dss-int.id {
	tls internal
	reverse_proxy app:3000 {
		# Next standalone doesn't trust X-Forwarded-* for nextUrl, so next-intl's
		# absolute locale redirects leak the internal listen port (:3000) into the
		# Location header. Strip it on the way back out.
		header_down Location ":3000/" "/"
	}
}
