# VCS
.git
.gitignore

# Dependencies & build output (rebuilt inside the image)
node_modules
.next
out
build

# Secrets & local env — must never enter the image
.env
.env.*
!.env.example

# Tooling / caches not needed at build time
.claude
.code-review-graph
.github
# NOTE: do not ignore `docs` — the mock-time page reads docs/time-mocking-api.md
# at runtime, and the Dockerfile copies it into the image.
tests
*.tsbuildinfo
README.md
